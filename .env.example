# ============================================================================
# Qdrant Cloud (for RAG vector storage)
# ============================================================================
# Get these from: https://cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_URL=https://xxxxx-xxxxx.us-east.aws.cloud.qdrant.io
QDRANT_COLLECTION_NAME=nawaloka

# ============================================================================
# Supabase (for memory system + CRM)
# ============================================================================
SUPABASE_DB_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=your_service_key_here

# ============================================================================
# LLM Providers
# ============================================================================
# OpenRouter (unified multi-provider access - recommended)
OPENROUTER_API_KEY=your_openrouter_key

# Direct providers (optional - use if not using OpenRouter)
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=your_anthropic_key
GOOGLE_API_KEY=your_google_key
GROQ_API_KEY=your_groq_key

# ============================================================================
# Redis (optional - for short-term memory if not using Supabase)
# ============================================================================
USE_SB_ST=true  # Set to false to use Redis instead
REDIS_URL=redis://localhost:6379

# ============================================================================
# External APIs
# ============================================================================
TAVILY_API_KEY=

# ============================================================================
# Observability Layer
# ============================================================================
LANGFUSE_SECRET_KEY = 
LANGFUSE_PUBLIC_KEY = 
LANGFUSE_BASE_URL = 